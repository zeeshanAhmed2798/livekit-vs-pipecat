# =============================================================
# VoxKit Pipecat Test — Environment Variables
# =============================================================
# Copy this file to .env and fill in your real values.
# =============================================================

# Daily.co (WebRTC transport)
# Get from: https://dashboard.daily.co → Developers → API keys
DAILY_API_KEY=your_daily_api_key
DAILY_API_URL=https://api.daily.co/v1

# Twilio (for call forwarding)
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Soniox STT
# Get from: https://console.soniox.com
SONIOX_API_KEY=your_soniox_api_key

# OpenAI (LLM + TTS)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Server port (optional, default 8000)
# PORT=8000
